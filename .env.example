# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/iot_db

# Application
APP_NAME=IoT Backend
DEBUG=False

# Security - JWT (Legacy, para compatibilidad)
SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Session Management - Valkey/Redis
VALKEY_URL=redis://localhost:6379/0

# Session Encryption - CRITICAL: Generate a secure 32-byte key
# Generate with: python -c "import secrets; import base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# Example (DO NOT USE IN PRODUCTION): dGVzdF9rZXlfMzJfYnl0ZXNfZXhhY3RseV9oZXJlXzEyMzQ1Njc4OQ==
ENCRYPTION_KEY=change-me-32-byte-base64-key-here
